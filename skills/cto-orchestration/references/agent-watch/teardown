#!/usr/bin/env bash
# Cleanly end a dispatched agent: kill the tmux session, remove its sentinel events
# file, and remove the per-agent hook config dispatch.sh dropped into the worktree.
# Usage: teardown <session> [cwd]
#   cwd = the worktree dispatch.sh used (to clean its .codex/hooks.json), optional.
set -u
SESSION="${1:?usage: teardown <session> [cwd]}"
CWD="${2:-}"
DIR="${AGENT_WATCH_DIR:-$HOME/.agents/run}"

tmux kill-session -t "$SESSION" 2>/dev/null && echo "killed tmux session $SESSION" || echo "no tmux session $SESSION"
rm -f "$DIR/$SESSION.events" 2>/dev/null && echo "removed sentinel $DIR/$SESSION.events"
if [ -n "$CWD" ] && [ -f "$CWD/.codex/hooks.json" ]; then
  rm -f "$CWD/.codex/hooks.json"; rmdir "$CWD/.codex" 2>/dev/null || true
  echo "removed $CWD/.codex hook config"
fi
exit 0
