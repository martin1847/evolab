#!/usr/bin/env bash
# Cleanly end a dispatched agent: kill the tmux session, remove its sentinel events
# file, and remove only the per-agent hook config this session created.
# Usage: teardown <session> [cwd]
#   cwd = the worktree dispatch used (to clean an owned Codex/Claude config), optional.
set -u
SESSION="${1:?usage: teardown <session> [cwd]}"
CWD="${2:-}"
DIR="${AGENT_WATCH_DIR:-/tmp/agent-watch-run}"

tmux kill-session -t "$SESSION" 2>/dev/null && echo "killed tmux session $SESSION" || echo "no tmux session $SESSION"
rm -f "$DIR/$SESSION.events" 2>/dev/null && echo "removed sentinel $DIR/$SESSION.events"
rm -f "$DIR/$SESSION.watch-armed" 2>/dev/null || true
OWNER="$DIR/$SESSION.hook-owner"
if [ -f "$OWNER" ] && [ -z "$CWD" ]; then
  echo "kept hook ownership marker $OWNER (pass cwd to clean the session-created config)" >&2
elif [ -f "$OWNER" ]; then
  [ -d "$CWD" ] || { echo "kept hook ownership marker $OWNER (cwd not found: $CWD)" >&2; exit 1; }
  CWD="$(cd "$CWD" && pwd -P)"
  kind="$(sed -n 's/^kind=//p' "$OWNER" | head -1)"
  owned_target="$(sed -n 's/^target=//p' "$OWNER" | head -1)"
  owned_fingerprint="$(sed -n 's/^cksum=//p' "$OWNER" | head -1)"
  case "$kind" in
    codex) expected="$CWD/.codex/hooks.json"; parent="$CWD/.codex" ;;
    claude) expected="$CWD/.claude/settings.json"; parent="$CWD/.claude" ;;
    *) echo "kept invalid hook ownership marker $OWNER" >&2; exit 1 ;;
  esac
  [ "$owned_target" = "$expected" ] || {
    echo "kept hook ownership marker $OWNER (owned path is $owned_target, not $expected)" >&2
    exit 1
  }
  target="$owned_target"
  [ -e "$target" ] || {
    echo "kept hook ownership marker $OWNER (owned config is missing: $target)" >&2
    exit 1
  }
  if [ -L "$target" ] || [ ! -f "$target" ]; then
    echo "kept hook ownership marker $OWNER (owned config is no longer a regular file: $target)" >&2
    exit 1
  fi
  canonical_target="$(cd "$(dirname "$target")" && printf '%s/%s\n' "$(pwd -P)" "$(basename "$target")")"
  [ "$canonical_target" = "$expected" ] || {
    echo "kept hook ownership marker $OWNER (owned config no longer resolves to $expected)" >&2
    exit 1
  }
  actual_fingerprint="$(cksum "$target" | awk '{print $1 ":" $2}')"
  [ -n "$owned_fingerprint" ] && [ "$actual_fingerprint" = "$owned_fingerprint" ] || {
    echo "kept hook ownership marker $OWNER (owned config content changed: $target)" >&2
    exit 1
  }
  rm -f "$target"
  rmdir "$parent" 2>/dev/null || true
  rm -f "$OWNER"
  echo "removed session-owned hook config $target"
fi
exit 0
