#!/usr/bin/env bash
# Unified dispatch: launch a coding agent in a tmux session wired to the hook-based
# agent-state watch (see README.md). Bakes in the two things that bite otherwise:
#   1) env set INSIDE the tmux command (a running tmux server freezes its env, so a
#      client-side prefix never reaches the pane → hook no-ops silently).
#   2) ABS substitution in codex/claude hook configs.
# Non-destructive: omp is fully automatic; codex/claude configs are CREATED only if
# absent, and if present we WARN + print the snippet (never clobber a user config).
# Usage:   dispatch <omp|codex|claude> <session> <cwd> [extra agent args...]
# Monitor: watch <session> [busy-marker]
set -uo pipefail
HERE_EARLY="$(cd "$(dirname "$0")" && pwd)"
RUN_EARLY="${AGENT_WATCH_DIR:-/tmp/agent-watch-run}"

# ── lane routing (interface/impl split) ───────────────────────────────────────
# `dispatch` is the stable INTERFACE. DEFAULT implementation = `dispatch-exec` (headless
# lane) — flipped 2026-07-12 (owner ruling) after TUI drift red-flagged a third release
# in a row (claude ≥2.1.205, then omp 16.4.4 + codex 0.144.1 both silently breaking hook
# load on the same day). Escape hatch back to the interactive TUI lane: DISPATCH_TUI=1
# (DISPATCH_EXEC=0 honored for muscle-memory back-compat; DISPATCH_EXEC=1 is now a no-op).
# The switch matters only at launch: send (below) self-routes by session state — an
# exec-lane session has $RUN/<s>.exec.meta — so later rounds follow the session's own
# lane even if the env var is gone (no cross-lane drift).
if [ "${DISPATCH_TUI:-0}" != "1" ] && [ "${DISPATCH_EXEC:-1}" != "0" ]; then
  case "${1:-}" in omp|codex|claude) exec "$HERE_EARLY/dispatch-exec" "$@" ;; esac
fi
if [ "${1:-}" = "send" ] && [ -n "${2:-}" ] && [ -f "$RUN_EARLY/${2}.exec.meta" ]; then
  exec "$HERE_EARLY/dispatch-exec" "$@"
fi
if [ "${1:-}" = "status" ]; then exec "$HERE_EARLY/dispatch-exec" "$@"; fi
# Pane-busy regex shared by `send` landed() and the --goal verify loop: codex's hook emits
# WORKING on PreToolUse (not turn start), so before its first tool call — or with hook untrusted —
# the events sentinel is silent and the pane busy marker is the only honest "it's working" signal.
BUSY_RE='esc to interrupt|Working \(|^[[:space:]]*Running '

# ── subcommand: dispatch send <session> -m "<text>" | -f <file> ───────────────
# Safely deliver a follow-up instruction (理解门放行 / 回修 / steering) to a RUNNING
# session AND verify it landed. Fixes the recurring stall: long 中文/①②③/全角冒号/@
# send-keys triggers omp's skill-popup that EATS Enter → message stuck in buffer, session
# sits idle, watcher can't tell "waiting for release" from "release didn't land" (2026-07-04
# 实证卡 24min). So: write instruction to a FILE, send-keys only a short ASCII "read <file>",
# clear any popup first, then poll events to CONFIRM transition to WORKING; retry once, warn if stuck.
if [ "${1:-}" = "send" ]; then
  sess="${2:?dispatch send <session> -m <text> | -f <file>}"; mode="${3:?-m|-f}"; arg="${4:?text-or-file}"
  case "$mode" in
    -f) file="$arg";;
    # No suffix after the X's: with one, macOS mktemp leaves the Xs LITERAL (fixed name →
    # 2nd -m send collides, "mkstemp failed") and GNU mktemp errors outright. This — not
    # too-few-Xs — was the root cause of the field-reported send collisions (2026-07-11).
    -m) file="$(mktemp "/tmp/dispatch-send-${sess}-XXXXXXXX")"; printf '%s\n' "$arg" > "$file";;
    *) echo "usage: dispatch send <session> -m <text> | -f <file>" >&2; exit 1;;
  esac
  [ -e "$file" ] || { echo "instruction file not found: $file" >&2; exit 1; }
  # Rotate the deliverable freshness epoch at DELIVERY time, before anything is sent: a
  # send IS a new round. Stamping at watch-arm time instead loses both directions — a fast
  # agent's file lands before a late-arming fused watch (false exit 6), and a rearm'd
  # watcher after SIGKILL measures round N against round N-1's stamp (false DONE).
  # (codex independent review 2026-07-11; watch keeps create-if-absent for mid-round rearm.)
  : > "$RUN_EARLY/$sess.watch-armed" 2>/dev/null || true
  ev="$RUN_EARLY/$sess.events"; before="$(wc -l < "$ev" 2>/dev/null || echo 0)"
  deliver() {
    tmux send-keys -t "$sess" Escape 2>/dev/null || true; sleep 0.6
    tmux send-keys -t "$sess" C-u 2>/dev/null || true; sleep 0.4
    tmux send-keys -t "$sess" "read $file and follow it strictly, then stop-and-report" 2>/dev/null; sleep 0.6
    tmux send-keys -t "$sess" Enter 2>/dev/null
  }
  # landed = agent started processing. Two signals: (a) omp writes "WORKING turn_start" to the events
  # file; (b) codex has NO events sentinel (its hook doesn't emit turn_start) -> fall back to the pane
  # busy marker ("Working (… esc to interrupt" / "esc to interrupt" / "Running"). Without (b) this
  # ALWAYS false-negatives on codex sessions (empty events file) and cries STUCK on a message that landed fine.
  landed() { local n; for _ in 1 2 3 4 5; do sleep 2
    n="$(wc -l < "$ev" 2>/dev/null || echo 0)"
    [ "$n" -gt "$before" ] && tail -n +"$((before+1))" "$ev" 2>/dev/null | grep -q "WORKING turn_start" && return 0
    tmux capture-pane -t "$sess" -p 2>/dev/null | grep -qiE "$BUSY_RE" && return 0
  done; return 1; }
  echo "[send] delivering '$file' → '$sess', verifying WORKING…"; deliver
  if landed; then echo "[send] OK — '$sess' is WORKING (landed)."; exit 0; fi
  echo "[send] WARN — no transition in 10s; retry once (popup may have eaten Enter)."; deliver
  if landed; then echo "[send] OK on retry."; exit 0; fi
  echo "[send] STILL STUCK — TUI may be wedged. inspect: tmux capture-pane -t $sess -p | tail -8" >&2; exit 2
fi
# ── launch mode (default) ─────────────────────────────────────────────────────
AGENT="${1:?usage: dispatch <omp|codex|claude> <session> <cwd> [args...]  |  dispatch send <session> -m/-f …}"
SESSION="${2:?session}"
CWD="${3:?cwd}"
shift 3 2>/dev/null || true
# `--goal <file>` fuses launch + goal-delivery + hook-verify + watch into ONE call: invoke this whole
# command via the Bash tool's run_in_background (NOT shell `&`) — no separate send step, no separate
# `watch` step to slip an `&` onto. Watch arms AUTOMATICALLY with --goal (there is no --watch flag:
# goal-without-watch has no doctrine-legit case, and watch-without-goal watches an idle agent and
# exits immediately — a flag that must only be used with another flag is an API footgun; removed at
# the source, design > guard). Works for codex review round 1 too (--goal <review-brief.md>): the
# verify loop falls back to the pane busy marker where codex has no sentinel yet (hook fires on first
# tool call, and only when trusted). Later rounds / steering = `dispatch send`. A first-ever codex
# OR claude launch in a cwd is ALSO one call: --goal auto-answers the directory-trust prompt (probe below).
WATCH_MODE=0; GOAL=""; DELIV=""
AGENT_ARGS=()
while [ "$#" -gt 0 ]; do
  case "$1" in
    --goal)
      [ "$#" -ge 2 ] || { echo "ERR: --goal requires a file" >&2; exit 1; }
      GOAL="$2"; WATCH_MODE=1; shift 2; continue ;;
    # --deliverable <glob>: arm the watch deliverable gate (see watch header, exit 6) —
    # DONE/idle only counts once the glob matches; use it whenever the goal's产出 is files.
    --deliverable)
      [ "$#" -ge 2 ] || { echo "ERR: --deliverable requires a glob" >&2; exit 1; }
      DELIV="$2"; shift 2; continue ;;
    *) AGENT_ARGS[${#AGENT_ARGS[@]}]="$1" ;;
  esac
  shift
done
[ -n "$DELIV" ] && export AGENT_WATCH_DELIVERABLE="$DELIV"
# The gate also PERSISTS per session (written below after DIR exists): env only lives in
# the watchspec, so a natural-exit + new-round rearm (gap-detect prints a bare `watch
# <sess>`) silently dropped the gate → false DONE (codex independent review 2026-07-11).
# validate BEFORE launching — failing after new-session would leak an orphan session
if [ -n "$GOAL" ] && [ ! -e "$GOAL" ]; then echo "ERR: --goal file not found: $GOAL" >&2; exit 1; fi
HERE="$(cd "$(dirname "$0")" && pwd)"
DIR="${AGENT_WATCH_DIR:-/tmp/agent-watch-run}"

# Build the command tmux's shell will execute without flattening caller argv. Bash 3.2
# supports indexed arrays + printf %q; every dynamic token is quoted exactly once.
quote_args() {
  local out="" arg q
  for arg in "$@"; do
    printf -v q '%q' "$arg"
    out="${out}${out:+ }${q}"
  done
  printf '%s' "$out"
}
ENVP="AGENT_WATCH_SESSION=$(quote_args "$SESSION") AGENT_WATCH_DIR=$(quote_args "$DIR")"

[ -d "$CWD" ] || { echo "ERR: cwd not found: $CWD" >&2; exit 1; }
CWD="$(cd "$CWD" && pwd -P)"
mkdir -p "$DIR" 2>/dev/null || true
if tmux has-session -t "$SESSION" 2>/dev/null; then echo "ERR: tmux session '$SESSION' already exists" >&2; exit 1; fi
# Retained exec-lane state hijacks a same-name TUI session: send/watch/teardown self-route
# by exec.meta presence, so a TUI reusing the name would lose its controls to the dead
# exec session (codex independent review 2026-07-11).
if [ -f "$DIR/$SESSION.exec.meta" ]; then
  echo "ERR: '$SESSION' has exec-lane state ($DIR/$SESSION.exec.meta) — teardown it or pick a new name" >&2; exit 1
fi
OWNER="$DIR/$SESSION.hook-owner"
rm -f "$OWNER" 2>/dev/null || true
: > "$DIR/$SESSION.events" 2>/dev/null || true                                  # fresh sentinel per dispatch
rm -f "$DIR/$SESSION.watch-armed" 2>/dev/null || true                           # stale arm stamp would poison the deliverable freshness gate
if [ -n "$DELIV" ]; then printf '%s\n' "$DELIV" > "$DIR/$SESSION.deliverable"   # persist the gate (see note above)
else rm -f "$DIR/$SESSION.deliverable" 2>/dev/null || true; fi
find "$DIR" -maxdepth 1 \( -name '*.events' -o -name '*.watch-armed' -o -name '*.deliverable' \) -mtime +7 -delete 2>/dev/null || true  # age-purge stale files

# Drop a per-agent hook config without clobbering an existing one.
# $1 = target config path, $2 = template filename under hooks/, $3 = owner kind
install_cfg() {
  local target="$1" tmpl="$HERE/hooks/$2" owner="$3"
  if [ -f "$target" ]; then
    echo "WARN: $target exists — NOT modifying. Merge this for the watch to work:" >&2
    sed "s#ABS#$HERE/hooks#g" "$tmpl" >&2
    return 0
  fi
  mkdir -p "$(dirname "$target")"
  if sed "s#ABS#$HERE/hooks#g" "$tmpl" > "$target"; then
    fingerprint="$(cksum "$target" | awk '{print $1 ":" $2}')"
    printf 'kind=%s\ntarget=%s\ncksum=%s\n' "$owner" "$target" "$fingerprint" > "$OWNER"
    echo "wrote $target (owned by session $SESSION)"
  fi
}

case "$AGENT" in
  omp)
    CMD="$ENVP $(quote_args omp --hook "$HERE/hooks/omp-watch.ts" ${AGENT_ARGS[@]+"${AGENT_ARGS[@]}"})" ;;
  codex)
    install_cfg "$CWD/.codex/hooks.json" codex-hooks.json codex
    # keep our tooling out of the tree: local exclude (not the shared .gitignore)
    if EX=$(git -C "$CWD" rev-parse --git-path info/exclude 2>/dev/null); then
      grep -qxF '.codex/' "$EX" 2>/dev/null || printf '.codex/\n' >> "$EX"
    fi
    # --dangerously-bypass-hook-trust: WE author the hooks.json this same run (vetted source,
    # the flag's documented intended use). Without it a FRESH cwd (worktree) has no persisted
    # hook trust in ~/.codex/config.toml → codex silently disables the whole file → zero emits
    # → every watch on the session exits 8 NO-HOOK (caught live 2026-07-11: events file
    # 0 bytes across two full review rounds — README promised this flag, launch line lacked it).
    CMD="$ENVP $(quote_args codex --dangerously-bypass-hook-trust ${AGENT_ARGS[@]+"${AGENT_ARGS[@]}"})" ;;
  claude)
    install_cfg "$CWD/.claude/settings.json" claude-hooks.json claude
    CMD="$ENVP $(quote_args claude ${AGENT_ARGS[@]+"${AGENT_ARGS[@]}"})" ;;
  *) echo "ERR: unknown agent '$AGENT' (omp|codex|claude)" >&2; exit 1 ;;
esac

tmux new-session -d -s "$SESSION" -c "$CWD" "$CMD"
echo "dispatched $AGENT → tmux session '$SESSION' (cwd $CWD)"
echo "events : $DIR/$SESSION.events"
# Engine visibility: a backend quota outage hits every session on that engine AT ONCE —
# omp/codex default to OpenAI backends, so exec + heterogeneous review can share one quota
# pool (operational single point; LH 2026-07-11: overnight insufficient_quota took both down
# while the orchestrator assumed omp was Claude). Say what was actually launched.
ARGS_SHOWN="${AGENT_ARGS[*]+${AGENT_ARGS[*]}}"
echo "engine : $AGENT — model/backend = the agent's own default unless overridden in args: ${ARGS_SHOWN:-<none>} (omp/codex default to OpenAI backends; check quota before high-volume runs)"
if [ -n "$GOAL" ]; then
  sleep 2  # let the agent TUI come up before delivering
  # codex AND claude first-ever launch in a cwd pause on a directory-trust prompt that would EAT
  # the goal text — auto-answer "1" (trust) so `dispatch <codex|claude> <s> <cwd> --goal <f>` is
  # truly ONE call even on first launch (omp has no such gate). claude's prompt is "…I trust this
  # folder", codex's is "do you trust…"; both matched below. (e2e dispatch-goal caught claude's
  # gate silently eating the goal — Martin 2026-07-05.)
  if [ "$AGENT" = "codex" ] || [ "$AGENT" = "claude" ]; then
    last_aff=""
    for _ in 1 2 3 4 5; do
      pane="$(tmux capture-pane -t "$SESSION" -p 2>/dev/null)"
      if printf '%s' "$pane" | grep -qiE "trust this|do you trust|allow codex|created or one you trust|bypass permissions|yes, i accept"; then
        # Answer by OPTION TEXT, never by position, and send the DIGIT ONLY — in these selectors
        # a number key confirms immediately; a trailing Enter lands on the NEXT dialog and confirms
        # its default. Bit us 2026-07-10 (claude ≥2.1.205): folder-trust (1=Yes) is followed by a
        # bypass-permissions acceptance whose default is 1=No,exit — the old "1"+Enter answered
        # dialog 1 with the digit, then Enter EXITED the agent on dialog 2. e2e claude leg all-red,
        # v1.3.3 baseline equally red — harness update, not a skill regression.
        aff_line="$(printf '%s' "$pane" | grep -oiE '[0-9][.)][^0-9]{0,40}(yes|accept|proceed|trust)' | head -1)"
        # Same dialog already answered (digit + Enter fallback exhausted) → it's a transition
        # residue in the pane, not a new gate; stray re-answers land in the CHAT INPUT as noise.
        if [ -n "$aff_line" ] && [ "$aff_line" = "$last_aff" ]; then sleep 2; continue; fi
        last_aff="$aff_line"
        ans="$(printf '%s' "$aff_line" | grep -oE '^[0-9]')"
        [ -n "$ans" ] || ans=1
        echo "── $AGENT trust/acceptance prompt detected → answering '$ans' (affirmative by text, digit first) ──"
        tmux send-keys -t "$SESSION" "$ans" 2>/dev/null; sleep 2
        # Enter ONLY if the very same dialog is still up (some TUIs need it, e.g. codex; claude's
        # confirms on the digit). Blind Enter would confirm the NEXT dialog's default instead.
        pane2="$(tmux capture-pane -t "$SESSION" -p 2>/dev/null)"
        if [ -n "$aff_line" ] && printf '%s' "$pane2" | grep -qiF "$aff_line"; then
          tmux send-keys -t "$SESSION" Enter 2>/dev/null; sleep 2
        fi
        continue  # a further gate may follow (folder trust → bypass acceptance); loop re-checks
      fi
      printf '%s' "$pane" | grep -qE "^›|gpt-|>[[:space:]]*$" && break  # prompt ready, no trust gate
      sleep 2
    done
  fi
  echo "── delivering goal via send: $GOAL ──"
  bash "$0" send "$SESSION" -f "$GOAL" || echo "WARN: goal delivery reported non-zero (check the session)"
fi
if [ "$WATCH_MODE" = 1 ]; then
  # verify hook wired (first WORKING or LOADED sentinel within ~12s) — same load-bearing check as the old
  # foreground "起后立刻验 hook" step, just written to output instead of returned synchronously.
  # Four tiers: WORKING (turn started) > LOADED (omp factory registered, turn pending) > pane
  # busy (working, sentinel pending — normal for codex before its first tool call) > neither
  # (alarm). Without the pane tier, codex --goal would
  # ALWAYS false-alarm "STOP and re-dispatch" on a review that landed fine.
  ok=""
  for _ in 1 2 3 4 5 6; do
    sleep 2
    grep -q " WORKING " "$DIR/$SESSION.events" 2>/dev/null && { ok=working; break; }
    grep -q " LOADED hook_loaded" "$DIR/$SESSION.events" 2>/dev/null && { ok=loaded; break; }
    tmux capture-pane -t "$SESSION" -p 2>/dev/null | grep -qiE "$BUSY_RE" && { ok=pane; break; }
  done
  case "$ok" in
    working) echo "hook: WORKING sentinel present — hook wired and turn started ✓ (Read this output line to confirm, then wait for the completion notification)" ;;
    loaded) echo "hook: LOADED sentinel present — omp hook factory registered; turn has not started yet ✓ (watch will keep waiting)" ;;
    pane) echo "hook: no sentinel yet but pane is BUSY — agent working (codex emits WORKING on first tool call, needs hook trust). watch keeps waiting while the pane is busy; a silent sentinel on an idle pane exits 8 NO-HOOK." ;;
    *)    echo "hook: NO sentinel after 12s and pane not busy — hook not wired / goal not landed / agent slow. watch will exit 8 NO-HOOK if this persists ~2min; STOP and re-dispatch rather than wait."
          # Quota/auth outages fail the very first tool call and look exactly like this tier —
          # name the real cause instead of letting it read as a wiring problem (LH 2026-07-11).
          tmux capture-pane -t "$SESSION" -p 2>/dev/null | grep -qiE 'insufficient_quota|invalid_api_key|No API key|credit balance|billing' \
            && echo "hook: pane shows a BACKEND QUOTA/AUTH error — the engine cannot run at all; fix credentials/quota before re-dispatching." ;;
  esac
  echo "── handing off to watch (blocks until terminal state; this background task completes when the agent is DONE/WAITING) ──"
  bash "$HERE/watch" "$SESSION"; rc=$?
  # The fused command's exit code IS the watch VERDICT (typed 0-7), and background-task
  # notifications render any nonzero as "command failed" — misread as dispatch failure 3+
  # times in the field while dispatch+goal delivery had succeeded (LH 2026-07-11). Spell the
  # verdict out in the OUTPUT (the thing the orchestrator actually reads): real dispatch
  # failures exit BEFORE the handing-off marker above.
  case "$rc" in
    0) v="DONE" ;;
    1) v="SESSION-GONE" ;;
    2) v="AGENT-DEAD (pane fell back to a shell)" ;;
    3) v="SUSPECTED-HANG" ;;
    4) v="WAITING-INPUT (agent needs a reply)" ;;
    5) v="STALLED-EXTERNAL (provider-error retry-loop — check backend quota/availability)" ;;
    6) v="IDLE-NO-DELIVERABLE (deliverable not produced this round — poke the agent)" ;;
    7) v="WATCH-TIMEOUT (agent still active — re-arm or verify)" ;;
    8) v="NO-HOOK (sentinel never fired, pane idle — hook unwired/untrusted; verify manually, then re-dispatch)" ;;
    *) v="unknown" ;;
  esac
  echo "== watch verdict: exit $rc = $v — NOT a dispatch failure (dispatch + goal delivery succeeded earlier in this output) =="
  exit "$rc"
else
  echo "monitor: bash $HERE/watch $SESSION   (or dispatch with --goal <file> to fuse launch+goal+watch into one run_in_background call)"
fi
