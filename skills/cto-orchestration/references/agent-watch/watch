#!/usr/bin/env bash
# Unified hook-based agent-state watcher (see README.md). PRIMARY signal = the
# sentinel events file written by the agent's lifecycle hook (deterministic, not
# screen-scraping). BACKSTOP = liveness guard (a hard crash emits no hook). FALLBACK
# = if no sentinel file appears, delegate to the screen-scrape (lib/scrape-fallback.sh) so
# nothing regresses when a session was launched without the hook.
# Usage: watch <tmux-session> [busy-marker] [shell-regex]
# Exit codes (same vocabulary as scrape-fallback): 0 DONE / 1 SESSION-GONE / 2 AGENT-DEAD
#   / 3 HANG / 4 WAITING-INPUT / 5 STALLED-EXTERNAL (provider-error retry-loop).
set -u
SESSION="${1:?usage: watch <session> [marker] [shell-regex]}"
MARKER="${2:-⟦esc⟧}"
SHELL_RE="${3:-^(-?zsh|-?bash|-?sh|login)$}"
# (C) External-provider stall: the agent is alive + WORKING but hot-retrying a TRANSIENT
# provider error (overload / rate-limit / 5xx). omp auto-retries it in place (auto_retry_start ->
# backoff -> continue, capped at retry.maxRetries~10): a fresh turn_start (WORKING) fires each retry
# but a terminal turn_end/DONE never does (only a non-retryable output-blocked error emits turn_end),
# and the screen repaints each retry — so neither DONE nor the hang heuristic (frozen screen) ever
# fires; the orchestrator waits silently for a terminal event that never comes (learned the hard way:
# a ~13min silent stall on overloaded_error).
# Detect the provider-error chrome repeated across consecutive polls and surface it. Pattern
# is intentionally SPECIFIC to error chrome (not bare "error" an agent writes while analyzing)
# and gated on WORKING + repetition, so an agent merely discussing errors won't false-positive.
# Override via AGENT_WATCH_EXT_ERR_RE.
EXT_ERR_RE="${AGENT_WATCH_EXT_ERR_RE:-(overloaded_error|rate_limit_error|stream error|429 Too Many|529 |Too Many Requests|insufficient_quota|service unavailable|Overloaded)}"
# (B2) Interactive-menu chrome: an agent's ask-user menu may NOT fire its WAITING hook
# (verified 2026-07-02: omp's clarify-menu emitted no `waiting` event -> events stayed
# stale-WORKING, screen frozen -> misclassified HANG exit 3, real state WAITING). Detect
# the menu UI chrome on a stale screen and classify WAITING instead. Pattern is UI-chrome
# specific (not content an agent typically prints); override via AGENT_WATCH_MENU_RE.
MENU_RE="${AGENT_WATCH_MENU_RE:-(enter select|Type to search|navigate.+select.+cancel)}"
DIR="${AGENT_WATCH_DIR:-$HOME/.agents/run}"
EVENTS="$DIR/$SESSION.events"
HERE="$(cd "$(dirname "$0")" && pwd)"

echo "=== [$SESSION] WATCH ARMED at $(date '+%H:%M:%S') pid $$ events=$EVENTS ==="

# Grace window for the hook to produce the first event; else fall back to scrape.
if [ ! -f "$EVENTS" ]; then
  sleep 6
  if [ ! -f "$EVENTS" ]; then
    echo "=== [$SESSION] no sentinel (hook not wired) → fallback to lib/scrape-fallback.sh ==="
    exec bash "$HERE/lib/scrape-fallback.sh" "$SESSION" "$MARKER" "$SHELL_RE"
  fi
fi

idle=0; lastline=""; stalls=0; exterr=0; empties=0
for i in {1..260}; do
  sleep 20
  # (A) liveness backstop FIRST — a hard crash fires no hook; foreground back to a
  #     shell => agent gone, not done.
  cmd=$(tmux display-message -p -t "$SESSION" '#{pane_current_command}' 2>/dev/null) \
    || { echo "=== [$SESSION] SESSION GONE at $(date '+%H:%M:%S') ==="; exit 1; }
  if [[ "$cmd" =~ $SHELL_RE ]]; then
    echo "=== [$SESSION] AGENT DEAD at $(date '+%H:%M:%S') — foreground '$cmd' ==="
    tmux capture-pane -t "$SESSION" -p 2>/dev/null | tail -30; exit 2
  fi

  line=$(tail -1 "$EVENTS" 2>/dev/null)
  state=$(printf '%s' "$line" | awk '{print $2}')

  # Empty-sentinel fallback: dispatch CREATES the events file empty, so the t=0
  # `! -f` grace above never trips when the hook simply never fires (e.g. codex
  # hooks not trusted → no events EVER). Result was a blind heartbeat spin. If the
  # file is still empty after ~2min (6 polls — generous vs an agent that just
  # hasn't started its first turn), the hook isn't delivering → switch to scrape.
  if [ -z "$line" ]; then
    empties=$((empties+1))
    if [ "$empties" -ge 6 ]; then
      echo "=== [$SESSION] sentinel empty ~2min (hook not firing / untrusted) → fallback to scrape ==="
      exec bash "$HERE/lib/scrape-fallback.sh" "$SESSION" "$MARKER" "$SHELL_RE"
    fi
    lastline="$line"
    [ $((i % 9)) -eq 0 ] && echo "[$SESSION] heartbeat iter $i state=empty $(date '+%H:%M:%S')"
    continue
  fi
  empties=0

  case "$state" in
    WAITING)
      echo "=== [$SESSION] WAITING FOR INPUT at $(date '+%H:%M:%S') — $line ==="
      tmux capture-pane -t "$SESSION" -p 2>/dev/null | tail -20; exit 4 ;;
    DONE)
      # Confirm a STABLE done (≥2 reads) so we don't exit on a transient turn
      # boundary right before an auto-continued next turn.
      idle=$((idle+1))
      if [ "$idle" -ge 2 ]; then
        echo "=== [$SESSION] DONE at $(date '+%H:%M:%S') — $line ==="
        tmux capture-pane -t "$SESSION" -p 2>/dev/null | tail -30; exit 0
      fi ;;
    *) idle=0 ;;  # WORKING / unknown
  esac

  # (B) hang heuristic: WORKING but the events file hasn't advanced for ~6min AND the
  #     screen is frozen => suspected stuck tool. Report, don't auto-kill.
  if [ "$state" = "WORKING" ]; then
    if [ "$line" = "$lastline" ]; then
      stalls=$((stalls+1))
      # (B2) stale ~1min + menu chrome on screen => the agent is WAITING on an
      # interactive menu whose hook never fired; don't let it ripen into a false HANG.
      if [ "$stalls" -ge 3 ] \
         && tmux capture-pane -t "$SESSION" -p 2>/dev/null | tail -15 | grep -qiE "$MENU_RE"; then
        echo "=== [$SESSION] WAITING FOR INPUT (menu chrome, hook missed) at $(date '+%H:%M:%S') ==="
        tmux capture-pane -t "$SESSION" -p 2>/dev/null | tail -20; exit 4
      fi
      if [ "$stalls" -ge 18 ]; then
        echo "=== [$SESSION] SUSPECTED HANG at $(date '+%H:%M:%S') — WORKING, no new event ~6min ==="
        tmux capture-pane -t "$SESSION" -p 2>/dev/null | tail -30; exit 3
      fi
    else stalls=0; fi
  fi

  # (C) external-provider stall (see header): WORKING + provider-error chrome on screen for
  #     ~3 consecutive polls (~1min) => hot-retry loop, not progress. Surface it (exit 5)
  #     instead of waiting silently for a DONE that won't come. NOT gated on a frozen screen
  #     (B's condition) because a retry loop keeps repainting.
  if [ "$state" = "WORKING" ] \
     && tmux capture-pane -t "$SESSION" -p 2>/dev/null | tail -15 | grep -qiE "$EXT_ERR_RE"; then
    exterr=$((exterr+1))
    if [ "$exterr" -ge 3 ]; then
      echo "=== [$SESSION] STALLED-EXTERNAL at $(date '+%H:%M:%S') — provider-error retry-loop ~$((exterr*20))s ==="
      tmux capture-pane -t "$SESSION" -p 2>/dev/null | tail -30; exit 5
    fi
  else exterr=0; fi
  lastline="$line"
  [ $((i % 9)) -eq 0 ] && echo "[$SESSION] heartbeat iter $i state=$state $(date '+%H:%M:%S')"
done
echo "=== [$SESSION] WATCH TIMEOUT — still active, last=$(tail -1 "$EVENTS" 2>/dev/null) ==="
