#!/usr/bin/env bash
# Unified hook-based agent-state watcher (see README.md). PRIMARY signal = the
# sentinel events file written by the agent's lifecycle hook (deterministic, not
# screen-scraping). BACKSTOP = liveness guard (a hard crash emits no hook). There is
# deliberately NO screen-scrape fallback (removed 2026-07-11, -190 lines): guessing
# state from the screen was the suite's biggest misjudgment source (WAITING read as
# DONE, glyph/layout drift) — a silent hook now exits 8 NO-HOOK instead of guessing.
# Usage: watch <tmux-session> [busy-regex] [shell-regex]
# Exit codes: 0 DONE / 1 SESSION-GONE / 2 AGENT-DEAD
#   / 3 HANG / 4 WAITING-INPUT / 5 STALLED-EXTERNAL (provider-error retry-loop)
#   / 6 IDLE-NO-DELIVERABLE (terminal-looking but declared deliverable never appeared)
#   / 7 WATCH-TIMEOUT (bounded polling exhausted while the agent stayed active)
#   / 8 NO-HOOK (sentinel silent + pane idle ~2min: hook not wired/firing — monitoring
#     impossible; verify the agent manually or re-dispatch via dispatch, never guess).
# (D) Deliverable gate — fixes "turn_end != task done" (4 false DONEs on 2026-07-05:
# multi-step agents emit DONE/idle at every turn/phase boundary; auto-continued next
# turns and codex inter-phase pauses read as terminal). Set AGENT_WATCH_DELIVERABLE
# to a path/glob: DONE/idle only exits 0 once >=1 match exists AND is newer than this
# round's arm stamp (existence alone early-exits multi-round goals — see STAMP below);
# still terminal-looking after AGENT_WATCH_NODELIV_POLLS (default 15) polls without it
# => exit 6 so the orchestrator POKES instead of trusting a phantom DONE.
# AGENT_WATCH_POLL_SECS (default 20) overrides poll interval (adversarial-testable).
set -u
SESSION="${1:?usage: watch <session> [busy-regex] [shell-regex]}"
# $2 = busy-pane regex (agent chrome proving "working"): keeps NO-HOOK honest for a codex
# whose hook only fires on its first tool call. Old watchspecs pass omp's ⟦esc⟧ glyph
# here — still a valid busy regex, so rearm'd pre-removal specs stay compatible.
BUSY_RE="${2:-esc to interrupt|Working \(|⟦esc⟧|^[[:space:]]*Running }"
SHELL_RE="${3:-^(-?zsh|-?bash|-?sh|login)$}"
# (C) External-provider stall: the agent is alive + WORKING but hot-retrying a TRANSIENT
# provider error (overload / rate-limit / 5xx). omp auto-retries it in place (auto_retry_start ->
# backoff -> continue, capped at retry.maxRetries~10): a fresh turn_start (WORKING) fires each retry
# but a terminal turn_end/DONE never does (only a non-retryable output-blocked error emits turn_end),
# and the screen repaints each retry — so neither DONE nor the hang heuristic (frozen screen) ever
# fires; the orchestrator waits silently for a terminal event that never comes (learned the hard way:
# a ~13min silent stall on overloaded_error).
# Detect the provider-error chrome repeated across consecutive polls and surface it. Pattern
# is intentionally SPECIFIC to error chrome (not bare "error" an agent writes while analyzing)
# and gated on WORKING + repetition, so an agent merely discussing errors won't false-positive.
# Override via AGENT_WATCH_EXT_ERR_RE.
EXT_ERR_RE="${AGENT_WATCH_EXT_ERR_RE:-(overloaded_error|rate_limit_error|stream error|429 Too Many|529 |Too Many Requests|insufficient_quota|service unavailable|Overloaded)}"
# (B2) Interactive-menu chrome: an agent's ask-user menu may NOT fire its WAITING hook
# (verified 2026-07-02: omp's clarify-menu emitted no `waiting` event -> events stayed
# stale-WORKING, screen frozen -> misclassified HANG exit 3, real state WAITING). Detect
# the menu UI chrome on a stale screen and classify WAITING instead. Pattern is UI-chrome
# specific (not content an agent typically prints); override via AGENT_WATCH_MENU_RE.
MENU_RE="${AGENT_WATCH_MENU_RE:-(enter select|Type to search|navigate.+select.+cancel)}"
DIR="${AGENT_WATCH_DIR:-/tmp/agent-watch-run}"
EVENTS="$DIR/$SESSION.events"
HERE="$(cd "$(dirname "$0")" && pwd)"

# Exec-lane session (headless twin) → delegate to its stateless watch; one `watch`
# entrypoint serves both lanes (interface/impl split, lane detected by session state).
[ -f "$DIR/$SESSION.exec.meta" ] && exec "$HERE/dispatch-exec" watch "$SESSION"

echo "=== [$SESSION] WATCH ARMED at $(date '+%H:%M:%S') pid $$ events=$EVENTS ==="

# ── watchspec self-heal registry ──────────────────────────────────────────────
# The harness can batch-SIGKILL background watchers (observed: context-compaction
# boundaries reap background shells). SIGKILL skips the EXIT trap, so the spec file
# SURVIVES an unnatural death; every natural exit removes it. `rearm` (sibling script)
# lists dead-watcher specs so the orchestrator can re-arm mechanically instead of
# remembering to.
SPEC="$DIR/$SESSION.watchspec"
# Deliverable freshness stamp: the gate must only accept files PRODUCED THIS ROUND. Existence
# alone early-exits multi-round goals — round-1's file satisfies the glob, so round-2/3's
# turn-boundary DONE sails through the gate while the agent is mid-work (LH 2026-07-11:
# identity/checkout2/npmconsume all hit). Create-if-absent (not truncate): SIGKILL leaves the
# stamp behind and a rearm'd watcher must keep the ORIGINAL arm time, not reset freshness
# mid-round. The EXIT trap removes it, so each new round's watch stamps its own arm time.
STAMP="$DIR/$SESSION.watch-armed"
[ -e "$STAMP" ] || : > "$STAMP"
# Per-session env must ride in the spec cmd, or a rearm'd watcher silently degrades to the
# ungated behavior (deliverable gate lost across SIGKILL+rearm — flagged by the gate's author).
SPEC_ENV=""
[ -n "${AGENT_WATCH_DELIVERABLE:-}" ] && SPEC_ENV="AGENT_WATCH_DELIVERABLE=$(printf %q "$AGENT_WATCH_DELIVERABLE") "
[ -n "${AGENT_WATCH_NODELIV_POLLS:-}" ] && SPEC_ENV="${SPEC_ENV}AGENT_WATCH_NODELIV_POLLS=$(printf %q "$AGENT_WATCH_NODELIV_POLLS") "
[ -n "${AGENT_WATCH_MAX_POLLS:-}" ] && SPEC_ENV="${SPEC_ENV}AGENT_WATCH_MAX_POLLS=$(printf %q "$AGENT_WATCH_MAX_POLLS") "
{
  printf 'session=%s\n' "$SESSION"
  printf 'pid=%s\n' "$$"
  printf 'cmd=%sbash %q %q %q %q\n' "$SPEC_ENV" "$HERE/watch" "$SESSION" "$BUSY_RE" "$SHELL_RE"
} > "$SPEC"
trap 'rm -f "$SPEC" "$STAMP"' EXIT

DELIVERABLE="${AGENT_WATCH_DELIVERABLE:-}"
# Env absent (bare re-arm from gap-detect: natural exit removed the watchspec that carried
# it) → fall back to the per-session persisted gate written by dispatch. Without this, a
# rearm'd watcher silently degraded to ungated and a turn-boundary DONE passed as real
# (codex independent review 2026-07-11).
[ -z "$DELIVERABLE" ] && [ -f "$DIR/$SESSION.deliverable" ] && DELIVERABLE="$(cat "$DIR/$SESSION.deliverable")"
NODELIV_MAX="${AGENT_WATCH_NODELIV_POLLS:-15}"
POLL="${AGENT_WATCH_POLL_SECS:-20}"
MAX_POLLS="${AGENT_WATCH_MAX_POLLS:-260}"
# No gate configured => always ok; else require >=1 glob match AT OR AFTER the arm stamp
# (freshness, see STAMP above — a leftover file from a previous round must not open the
# gate). `! -ot`, not `-nt`: strict-newer has second granularity, so a same-second valid
# deliverable was rejected (codex independent review 2026-07-11; parity with exec lane).
deliverable_ok() {
  [ -z "$DELIVERABLE" ] && return 0
  local f
  while IFS= read -r f; do
    [ -n "$f" ] || continue
    ! [ "$f" -ot "$STAMP" ] && return 0
  done < <(compgen -G "$DELIVERABLE" 2>/dev/null)
  return 1
}

idle=0; lastline=""; stalls=0; exterr=0; empties=0; nodeliv=0; busywait=0
i=1
while [ "$i" -le "$MAX_POLLS" ]; do
  sleep "$POLL"
  # (A) liveness backstop FIRST — a hard crash fires no hook; foreground back to a
  #     shell => agent gone, not done.
  cmd=$(tmux display-message -p -t "$SESSION" '#{pane_current_command}' 2>/dev/null) \
    || { echo "=== [$SESSION] SESSION GONE at $(date '+%H:%M:%S') ==="; exit 1; }
  if [[ "$cmd" =~ $SHELL_RE ]]; then
    echo "=== [$SESSION] AGENT DEAD at $(date '+%H:%M:%S') — foreground '$cmd' ==="
    tmux capture-pane -t "$SESSION" -p 2>/dev/null | tail -30; exit 2
  fi

  line=$(tail -1 "$EVENTS" 2>/dev/null)
  state=$(printf '%s' "$line" | awk '{print $2}')

  # Silent sentinel (file absent OR still empty — dispatch creates it empty; codex with
  # untrusted hooks never writes): a BUSY pane means the agent is working before its first
  # emit (codex fires on the first tool call) → keep waiting, MAX_POLLS still bounds us.
  # Idle pane for ~2min (6 polls) = hook not delivering AND nothing running → exit 8
  # NO-HOOK: monitoring is impossible; report honestly instead of guessing from the screen
  # (the removed scrape fallback was the suite's biggest misjudgment source — WAITING
  # mis-read as DONE dispatched a still-waiting agent to review).
  if [ -z "$line" ]; then
    # Busy-chrome residue can keep this alive forever: an idle prompt with a leftover line
    # like "Running tests…" matches BUSY_RE every poll, deferring NO-HOOK to the ~87min
    # MAX_POLLS timeout (codex independent review 2026-07-11). Busy defers — but bounded:
    # a hook that has emitted NOTHING in ~10min of "busy" is definitively not delivering.
    if tmux capture-pane -t "$SESSION" -p 2>/dev/null | grep -qiE "$BUSY_RE"; then
      empties=0; busywait=$((busywait+1))
      if [ "$busywait" -ge 30 ]; then
        echo "=== [$SESSION] NO-HOOK at $(date '+%H:%M:%S') — pane looks busy but sentinel silent ~10min; hook not delivering (or busy-chrome residue on an idle prompt). Verify manually or re-dispatch. ==="
        tmux capture-pane -t "$SESSION" -p 2>/dev/null | tail -20; exit 8
      fi
    else
      empties=$((empties+1))
      if [ "$empties" -ge 6 ]; then
        echo "=== [$SESSION] NO-HOOK at $(date '+%H:%M:%S') — sentinel silent ~2min and pane idle; hook not wired/firing. Verify the agent manually or re-dispatch via dispatch. ==="
        tmux capture-pane -t "$SESSION" -p 2>/dev/null | tail -20; exit 8
      fi
    fi
    lastline="$line"
    [ $((i % 9)) -eq 0 ] && echo "[$SESSION] heartbeat iter $i state=empty $(date '+%H:%M:%S')"
    i=$((i+1))
    continue
  fi
  empties=0; busywait=0

  case "$state" in
    WAITING)
      echo "=== [$SESSION] WAITING FOR INPUT at $(date '+%H:%M:%S') — $line ==="
      tmux capture-pane -t "$SESSION" -p 2>/dev/null | tail -20; exit 4 ;;
    DONE)
      # Confirm a STABLE done (≥2 reads) so we don't exit on a transient turn
      # boundary right before an auto-continued next turn.
      idle=$((idle+1))
      if [ "$idle" -ge 2 ]; then
        if deliverable_ok; then
          echo "=== [$SESSION] DONE at $(date '+%H:%M:%S') — $line ==="
          tmux capture-pane -t "$SESSION" -p 2>/dev/null | tail -30; exit 0
        fi
        # (D) DONE-looking but declared deliverable missing: this is a turn boundary,
        # not task completion — keep watching instead of reporting a phantom DONE.
        nodeliv=$((nodeliv+1))
        [ "$nodeliv" -eq 1 ] && echo "[$SESSION] DONE event but deliverable '$DELIVERABLE' missing → continuing watch"
        if [ "$nodeliv" -ge "$NODELIV_MAX" ]; then
          echo "=== [$SESSION] IDLE-NO-DELIVERABLE at $(date '+%H:%M:%S') — stable DONE but '$DELIVERABLE' never appeared; poke the agent ==="
          tmux capture-pane -t "$SESSION" -p 2>/dev/null | tail -30; exit 6
        fi
      fi ;;
    *) idle=0; nodeliv=0 ;;  # WORKING / unknown
  esac

  # (B) hang heuristic: WORKING but the events file hasn't advanced for ~6min AND the
  #     screen is frozen => suspected stuck tool. Report, don't auto-kill.
  if [ "$state" = "WORKING" ]; then
    if [ "$line" = "$lastline" ]; then
      stalls=$((stalls+1))
      # (B2) stale ~1min + menu chrome on screen => the agent is WAITING on an
      # interactive menu whose hook never fired; don't let it ripen into a false HANG.
      if [ "$stalls" -ge 3 ] \
         && tmux capture-pane -t "$SESSION" -p 2>/dev/null | tail -15 | grep -qiE "$MENU_RE"; then
        echo "=== [$SESSION] WAITING FOR INPUT (menu chrome, hook missed) at $(date '+%H:%M:%S') ==="
        tmux capture-pane -t "$SESSION" -p 2>/dev/null | tail -20; exit 4
      fi
      if [ "$stalls" -ge 18 ]; then
        # The events file can stall for ~6min during a long recon/sub-agent phase while the
        # pane is very much alive (spinner + sub-agent progress repainting). Event-staleness
        # alone therefore false-positives HANG (observed 2026-07-03: omp mid-recon, sub-agent
        # running, tripped exit 3). Before declaring HANG, ACTUALLY verify the screen is frozen
        # (the condition this heuristic always claimed): two captures ~3s apart must be identical.
        # Differ (spinner animating / progress moving) ⇒ alive ⇒ defer, don't over-fire.
        snap1=$(tmux capture-pane -t "$SESSION" -p 2>/dev/null)
        sleep 3
        snap2=$(tmux capture-pane -t "$SESSION" -p 2>/dev/null)
        if [ "$snap1" = "$snap2" ]; then
          echo "=== [$SESSION] SUSPECTED HANG at $(date '+%H:%M:%S') — WORKING, no new event ~6min AND screen frozen ==="
          printf '%s\n' "$snap2" | tail -30; exit 3
        fi
        # screen still moving → not hung; hold the stall counter just below threshold so we
        # re-check on the next quiet stretch instead of waiting another full 6min.
        stalls=17
      fi
    else stalls=0; fi
  fi

  # (C) external-provider stall (see header): WORKING + provider-error chrome on screen for
  #     ~3 consecutive polls (~1min) => hot-retry loop, not progress. Surface it (exit 5)
  #     instead of waiting silently for a DONE that won't come. NOT gated on a frozen screen
  #     (B's condition) because a retry loop keeps repainting.
  if [ "$state" = "WORKING" ] \
     && tmux capture-pane -t "$SESSION" -p 2>/dev/null | tail -15 | grep -qiE "$EXT_ERR_RE"; then
    exterr=$((exterr+1))
    if [ "$exterr" -ge 3 ]; then
      echo "=== [$SESSION] STALLED-EXTERNAL at $(date '+%H:%M:%S') — provider-error retry-loop ~$((exterr*20))s ==="
      tmux capture-pane -t "$SESSION" -p 2>/dev/null | tail -30; exit 5
    fi
  else exterr=0; fi
  lastline="$line"
  [ $((i % 9)) -eq 0 ] && echo "[$SESSION] heartbeat iter $i state=$state $(date '+%H:%M:%S')"
  i=$((i+1))
done
echo "=== [$SESSION] WATCH TIMEOUT — still active, last=$(tail -1 "$EVENTS" 2>/dev/null) ==="
exit 7
