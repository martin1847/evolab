#!/usr/bin/env bash
# dispatch-exec — headless dispatch (PROTOTYPE, exec lane twin of `dispatch`).
# tmux is a process SUPERVISOR only (worker survives orchestrator restarts — tmux server
# is its own daemon); the pane runs a NON-interactive engine. What that buys vs the TUI
# lane: no trust dialogs, no send-keys/popups, no screen guessing. Terminal truth is only
# the typed result from `status`/`watch` (never a raw engine rc). State lives in FILES, so they are
# STATELESS — a reaped watcher loses nothing (no watchspec/rearm machinery needed).
# Steering = resume rounds (same engine session, context kept):
#   round 1  : dispatch-exec <omp|codex|claude> <session> <cwd> --goal <f> [--deliverable <glob>]
#              [--workflow review-loop --max-rounds N] [engine args...]
#   round N  : dispatch-exec send <session> (-f <file> | -m <text>)
#   query    : dispatch-exec status <session>          (one-shot, stateless)
#   block    : dispatch-exec watch  <session>          (poll until terminal; typed exit, same vocab as watch)
# Ask-user protocol (headless agents can't prompt): every round prompt carries a footer —
# "on doubt, write BLOCKED.md to the cwd and stop"; a fresh BLOCKED.md maps to exit 4 WAITING-INPUT.
# NOT a transaction system (owner ruling 2026-07-12): concurrent dispatch against one
# session is an orchestrator-discipline bug — the pid lock below only stops the obvious
# double-send footgun. No reaper, no rollback: a round torn mid-transition is recovered
# by teardown + re-dispatch, not by machinery.
# Engine facts baked in (probed 2026-07-11, all three on this machine):
#   claude: -p --output-format json → result frame has session_id; resume MUST run in the
#           SAME cwd (sessions are project-scoped — cross-cwd resume finds nothing).
#   codex : exec --json emits thread.started{thread_id}; `exec resume <id>`; -o writes the
#           last message to a file. Exit code UNVERIFIED as truth → also grep turn.failed.
#   omp   : -p --mode=json JSONL; --session-dir pins session storage per dispatch so the
#           newest file there is unambiguously ours; resume = -r <session-file-path>.
set -uo pipefail
DIR="${AGENT_WATCH_DIR:-/tmp/agent-watch-run}"

meta_get() { sed -n "s/^$2=//p" "$DIR/$1.exec.meta" 2>/dev/null | head -1; }
q() { printf %q "$1"; }
# Output of the CURRENT round only — the out file accumulates rounds, and grepping the
# whole file misclassified round 2 by matching error tokens QUOTED in round 1's review
# prose (self-caught 2026-07-11).
last_round() { awk '/^── round [0-9]+ @/{buf=""; next} {buf=buf $0 RS} END{printf "%s", buf}' "$DIR/$1.exec.out" 2>/dev/null; }

LOCKFILE=""
take_round_lock() { # $1 session — thin double-send guard: holder alive → refuse; dead → take over
  LOCKFILE="$DIR/$1.exec.lock"
  local pid; pid="$(cat "$LOCKFILE" 2>/dev/null || true)"
  if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
    echo "ERR: round transition already in progress for '$1' (pid $pid) — wait, or teardown after verification" >&2
    return 1
  fi
  printf '%s\n' "$$" > "$LOCKFILE"
  trap 'rm -f "$LOCKFILE"' EXIT
  trap 'exit 130' HUP INT TERM   # route signals through EXIT so the lock never leaks
}

check_round_budget() { # $1 session — caller holds the round lock
  local s="$1" round workflow max_rounds
  round="$(meta_get "$s" round)"; workflow="$(meta_get "$s" workflow)"
  max_rounds="$(meta_get "$s" max_rounds)"
  if [ "$workflow" = "review-loop" ] && [ "$round" -ge "$max_rounds" ]; then
    echo "BUDGET-EXHAUSTED: review-loop '$s' reached max-rounds=$max_rounds (current round=$round)" >&2
    return 9
  fi
  return 0
}

# Preserve the caller's prompt byte-for-byte as a prefix, then append the same non-interactive
# protocol to EVERY round. A distinct file per round keeps the source goal/fix brief untouched.
build_round_prompt() { # $1 session  $2 round  $3 cwd  $4 source-prompt
  local s="$1" round="$2" cwd="$3" src="$4" out
  out="$(mktemp "$DIR/$s.exec.prompt-r${round}-XXXXXXXX")" || return 1
  cat "$src" > "$out" || { rm -f "$out"; return 1; }
  printf '\n\n---\nHEADLESS ROUND PROTOCOL\n%s\n%s\n%s\n' \
    'Briefly restate the files/contracts, scope, and main risk, then start work immediately. Do not wait for approval or interaction.' \
    'This round is non-interactive. Complete the prompt and stop.' \
    "If genuinely blocked, write the blocker to $cwd/BLOCKED.md and stop." >> "$out"
  printf '%s\n' "$out"
}

# ── build the engine command for a round; echoes the shell string the pane runs ──
# $1 engine  $2 session  $3 cwd  $4 prompt-file  $5 sid ("" = round 1)  $6 extra args (pre-quoted)
engine_cmd() {
  local eng="$1" s="$2" cwd="$3" f="$4" sid="$5" extra="$6" out lastf sdir
  out="$DIR/$s.exec.out"; lastf="$DIR/$s.exec.last"; sdir="$DIR/$s.omp-sessions"
  case "$eng" in
    claude)
      if [ -z "$sid" ]; then echo "claude -p \"\$(cat $(q "$f"))\" --output-format json $extra"
      else echo "claude -p --resume $(q "$sid") \"\$(cat $(q "$f"))\" --output-format json $extra"; fi ;;
    codex)
      if [ -z "$sid" ]; then echo "codex exec --dangerously-bypass-hook-trust --json --skip-git-repo-check -C $(q "$cwd") -o $(q "$lastf") $extra - < $(q "$f")"
      else
        # `codex exec resume` rejects -s/--sandbox/-C (the resumed session keeps its
        # original cwd/sandbox) — passing launch args verbatim killed round 2 on argv
        # (self-caught: codex's own re-review round, 2026-07-11). Strip them; keep the rest.
        local filtered="" skip=0 a
        eval "set -- $extra"
        for a in "$@"; do
          if [ "$skip" = 1 ]; then skip=0; continue; fi
          case "$a" in -s|--sandbox|-C|--cd) skip=1 ;; *) filtered="${filtered}${filtered:+ }$(q "$a")" ;; esac
        done
        echo "codex exec resume $(q "$sid") --dangerously-bypass-hook-trust --json -o $(q "$lastf") $filtered - < $(q "$f")"
      fi ;;
    omp)
      if [ -z "$sid" ]; then echo "omp -p \"\$(cat $(q "$f"))\" --mode=json --session-dir $(q "$sdir") $extra"
      else echo "omp -p -r $(q "$sid") \"\$(cat $(q "$f"))\" --mode=json --session-dir $(q "$sdir") $extra"; fi ;;
  esac
}

# ── start one round under the tmux supervisor ──  $1 session  $2 prompt-file
start_round() { # $1 session  $2 prompt-file  $3 optional: lock already held
  local s="$1" f="$2" lock_held="${3:-0}" eng cwd sid extra cmd round round_prompt
  if [ "$lock_held" != 1 ]; then
    take_round_lock "$s" || exit 1
    check_round_budget "$s" || exit $?
  fi
  eng="$(meta_get "$s" engine)"; cwd="$(meta_get "$s" cwd)"
  sid="$(meta_get "$s" sid)"; extra="$(meta_get "$s" args)"; round="$(meta_get "$s" round)"
  if [ "$round" -gt 0 ]; then
    harvest_sid "$s" || { echo "ERR: could not persist engine session id for '$s'" >&2; exit 1; }
    sid="$(meta_get "$s" sid)"
    [ -n "$sid" ] || { echo "ERR: no engine session id discovered yet — did round 1 finish?" >&2; exit 1; }
  fi
  if tmux has-session -t "$s" 2>/dev/null; then
    echo "ERR: previous round of '$s' still running (tmux session exists) — wait or teardown" >&2; exit 1
  fi
  round=$((round+1))
  round_prompt="$(build_round_prompt "$s" "$round" "$cwd" "$f")" || {
    echo "ERR: failed to build headless prompt for '$s' round $round" >&2; exit 1
  }
  cmd="$(engine_cmd "$eng" "$s" "$cwd" "$round_prompt" "$sid" "$extra")"
  # Launch FIRST, mutate state only on success: the unchecked-failure path once printed
  # success, orphaned round-1 meta (permanent lane hijack) and destroyed the previous
  # round's rc (codex independent review 2026-07-11). The engine needs its first ~50ms+
  # of CLI startup before touching out/rc, so the post-launch writes below win that race
  # in practice; a crash in between is teardown-recoverable (see header — no rollback).
  if ! tmux new-session -d -s "$s" -c "$cwd" "$cmd >> $(q "$DIR/$s.exec.out") 2>&1; echo \$? > $(q "$DIR/$s.exec.rc")"; then
    echo "ERR: tmux new-session failed for '$s' (round $round not started)" >&2
    rm -f "$round_prompt"; [ "$round" = 1 ] && rm -f "$DIR/$s.exec.meta"
    exit 1
  fi
  sed -i '' "s/^round=.*/round=$round/" "$DIR/$s.exec.meta" 2>/dev/null \
    || sed -i "s/^round=.*/round=$round/" "$DIR/$s.exec.meta"
  rm -f "$DIR/$s.exec.rc"
  : > "$DIR/$s.exec.round-started"                       # freshness stamp: deliverable/BLOCKED must postdate this
  printf '── round %s @ %s ──\n' "$round" "$(date '+%F %T')" >> "$DIR/$s.exec.out"
  echo "round $round started: $eng → tmux '$s' (supervisor only; engine is headless)"
  echo "out: $DIR/$s.exec.out"
  echo "status: dispatch status $s"
}

# ── discover is pure-read (status/watch never mutate meta); harvest persists, writers only ──
discover_sid() { # $1 session; prints discovered id or empty
  local s="$1" eng sid=""
  eng="$(meta_get "$s" engine)"
  case "$eng" in
    claude) sid="$(grep -o '"session_id":"[^"]*"' "$DIR/$s.exec.out" 2>/dev/null | tail -1 | cut -d'"' -f4)" ;;
    codex)  sid="$(grep -o '"thread_id":"[^"]*"' "$DIR/$s.exec.out" 2>/dev/null | tail -1 | cut -d'"' -f4)" ;;
    omp)    sid="$(ls -t "$DIR/$s.omp-sessions"/*.jsonl 2>/dev/null | head -1)" ;;
  esac
  printf '%s\n' "$sid"
}
harvest_sid() { # $1 session; called from start_round only (under the round lock)
  local s="$1" sid tmp
  sid="$(discover_sid "$s")"
  [ -n "$sid" ] || return 0
  # Rewrite, don't sed-substitute: omp sids are PATHS and legal `&`/`|` in them are sed
  # replacement metacharacters — a second harvest corrupted the stored sid (codex
  # independent review 2026-07-11).
  tmp="$(mktemp "$DIR/$s.exec.meta-XXXXXXXX")" || return 1
  { grep -v '^sid=' "$DIR/$s.exec.meta" 2>/dev/null; printf 'sid=%s\n' "$sid"; } > "$tmp" \
    && mv "$tmp" "$DIR/$s.exec.meta"
  [ -e "$tmp" ] && rm -f "$tmp"
  return 0
}

# ── classify a session's state; prints one line, returns the typed code ──
classify() { # $1 session
  local s="$1" cwd deliv rc stamp="$DIR/$1.exec.round-started"
  cwd="$(meta_get "$s" cwd)"; deliv="$(meta_get "$s" deliverable)"
  if [ ! -f "$DIR/$s.exec.rc" ]; then
    if tmux has-session -t "$s" 2>/dev/null; then echo "RUNNING (engine alive under tmux supervisor)"; return 10; fi
    echo "AGENT-DEAD: no rc and no tmux session — round was killed mid-flight; resume via send"; return 2
  fi
  rc="$(cat "$DIR/$s.exec.rc")"
  # `! -ot` (>= stamp), not `-nt`: -nt is strictly-newer with SECOND granularity — a round
  # that writes BLOCKED.md within the same second as its own arm stamp would read as DONE.
  if [ -f "$cwd/BLOCKED.md" ] && ! [ "$cwd/BLOCKED.md" -ot "$stamp" ]; then
    echo "WAITING-INPUT: agent wrote BLOCKED.md — read it, answer via send"; return 4
  fi
  if [ "$rc" != 0 ] && last_round "$s" | grep -qiE 'insufficient_quota|invalid_api_key|No API key|credit balance'; then
    echo "STALLED-EXTERNAL: backend quota/auth error (rc=$rc) — fix credentials, then send to retry"; return 5
  fi
  # codex exit code unverified as truth: a failed turn can still exit 0 → check events too.
  if [ "$rc" != 0 ] || last_round "$s" | tail -5 | grep -q '"type":"turn.failed"'; then
    echo "FAILED: engine rc=$rc (or turn.failed event) — read $DIR/$s.exec.out tail"; return 2
  fi
  if [ -n "$deliv" ]; then
    local f ok=1
    while IFS= read -r f; do [ -n "$f" ] && ! [ "$f" -ot "$stamp" ] && ok=0 && break
    done < <(compgen -G "$deliv" 2>/dev/null)
    [ "$ok" = 0 ] || { echo "IDLE-NO-DELIVERABLE: rc=0 but '$deliv' not produced this round — read output, then dispatch send $s; do not teardown"; return 6; }
  fi
  echo "DONE: rc=0$([ -n "$deliv" ] && echo ", deliverable fresh")"; return 0
}

case "${1:-}" in
  send)
    s="${2:?dispatch-exec send <session> -m <text> | -f <file>}"; mode="${3:?-m|-f}"; arg="${4:?text-or-file}"
    case "$mode" in
      -f) f="$arg";;
      -m) f="";;
      *) echo "usage: dispatch-exec send <session> -m <text> | -f <file>" >&2; exit 1;;
    esac
    [ -f "$DIR/$s.exec.meta" ] || { echo "ERR: unknown session '$s' (no meta)" >&2; exit 1; }
    [ "$mode" != -f ] || [ -e "$f" ] || { echo "ERR: file not found: $f" >&2; exit 1; }
    take_round_lock "$s" || exit 1
    # Stop-loss must precede every send-side mutation, including creation of the -m temp file.
    check_round_budget "$s" || exit $?
    if [ "$mode" = -m ]; then
      # No suffix after the X's: macOS mktemp leaves Xs LITERAL with a suffix (fixed name,
      # 2nd call = mkstemp failed) and GNU errors outright — the true root cause of the
      # long-standing "mktemp collision" (misdiagnosed as too-few-Xs, 2026-07-11).
      f="$(mktemp "$DIR/$s.exec.msg-XXXXXXXX")" || exit 1
      printf '%s\n' "$arg" > "$f"
    fi
    start_round "$s" "$f" 1
    ;;
  status)
    s="${2:?dispatch-exec status <session>}"
    classify "$s"; rc=$?
    shown_sid="$(meta_get "$s" sid)"; [ -n "$shown_sid" ] || shown_sid="$(discover_sid "$s")"
    echo "meta: engine=$(meta_get "$s" engine) round=$(meta_get "$s" round) sid=$shown_sid"
    exit "$rc"
    ;;
  watch)
    s="${2:?dispatch-exec watch <session>}"
    POLL="${AGENT_WATCH_POLL_SECS:-15}"; MAX="${AGENT_WATCH_MAX_POLLS:-240}"
    echo "=== [$s] EXEC-WATCH ARMED at $(date '+%H:%M:%S') (stateless — safe to kill and re-run) ==="
    i=1
    while [ "$i" -le "$MAX" ]; do
      msg="$(classify "$s")"; rc=$?
      if [ "$rc" != 10 ]; then
        echo "=== [$s] $msg ==="; tail -3 "$DIR/$s.exec.out" 2>/dev/null; exit "$rc"
      fi
      [ $((i % 12)) -eq 0 ] && echo "[$s] heartbeat iter $i still running $(date '+%H:%M:%S')"
      i=$((i+1)); sleep "$POLL"
    done
    echo "=== [$s] WATCH TIMEOUT — engine still running; re-run watch or investigate ==="; exit 7
    ;;
  omp|codex|claude)
    ENG="$1"; S="${2:?session}"; CWD="${3:?cwd}"; shift 3
    GOAL=""; DELIV=""; WORKFLOW=""; MAX_ROUNDS=""; EXTRA=""
    while [ "$#" -gt 0 ]; do case "$1" in
      --goal) GOAL="${2:?}"; shift 2;;
      --deliverable) DELIV="${2:?}"; shift 2;;
      --workflow) WORKFLOW="${2:?}"; shift 2;;
      --max-rounds) MAX_ROUNDS="${2:?}"; shift 2;;
      *) EXTRA="${EXTRA}${EXTRA:+ }$(q "$1")"; shift;;
    esac; done
    if [ -n "$WORKFLOW" ] || [ -n "$MAX_ROUNDS" ]; then
      [ "$WORKFLOW" = "review-loop" ] && [ -n "$MAX_ROUNDS" ] || {
        echo "ERR: --workflow review-loop and --max-rounds N must be provided together" >&2; exit 1
      }
      case "$MAX_ROUNDS" in ''|*[!0-9]*)
        echo "ERR: --max-rounds must be a positive integer" >&2; exit 1;;
      esac
      [ "$MAX_ROUNDS" -gt 0 ] || { echo "ERR: --max-rounds must be a positive integer" >&2; exit 1; }
    fi
    [ -n "$GOAL" ] && [ -e "$GOAL" ] || { echo "ERR: --goal <file> required and must exist" >&2; exit 1; }
    [ -d "$CWD" ] || { echo "ERR: cwd not found: $CWD" >&2; exit 1; }
    CWD="$(cd "$CWD" && pwd -P)"
    mkdir -p "$DIR"
    [ -f "$DIR/$S.exec.meta" ] && { echo "ERR: session '$S' already exists ($DIR/$S.exec.meta) — teardown or pick a new name" >&2; exit 1; }
    # Collision check BEFORE writing meta: start_round's guard fires too late — a failed
    # launch would orphan the meta and permanently self-route that (TUI) session name into
    # the exec lane (P1, independent review 2026-07-11).
    if tmux has-session -t "$S" 2>/dev/null; then echo "ERR: tmux session '$S' already exists" >&2; exit 1; fi
    { printf 'engine=%s\ncwd=%s\nround=0\nargs=%s\n' "$ENG" "$CWD" "$EXTRA"
      [ -n "$DELIV" ] && printf 'deliverable=%s\n' "$DELIV"; } > "$DIR/$S.exec.meta"
    if [ -n "$WORKFLOW" ]; then
      printf 'workflow=%s\nmax_rounds=%s\n' "$WORKFLOW" "$MAX_ROUNDS" >> "$DIR/$S.exec.meta"
    fi
    start_round "$S" "$GOAL"
    echo "monitor: dispatch status $S   (typed one-shot)  |  watch $S  (blocking, run_in_background)"
    ;;
  *)
    echo "usage: dispatch-exec <omp|codex|claude> <session> <cwd> --goal <f> [--deliverable <glob>] [--workflow review-loop --max-rounds N] [engine args...]" >&2
    echo "       dispatch-exec send <session> (-f <file> | -m <text>) | status <session> | watch <session>" >&2
    exit 1
    ;;
esac
