#!/usr/bin/env bash
# agent-mail agentbus helper — inter-orchestrator mailbox ops. Pure bash, no deps.
# Bus root = $AGENT_MAIL_DIR (default ~/.agents/mail) — USER DATA, deliberately outside
# this skill's directory so publishing/upgrading the skill never touches mail.
set -euo pipefail
# Owner-only by default: mail is untrusted data on a shared trust boundary (the fs user),
# so every dir/file this helper creates must be unreadable to other users. umask 077 makes
# mkdir→700 and file-create→600 without a chmod after each op (structural, not discipline —
# a forgotten chmod is the exact leak this prevents). Pre-existing loose perms: see SKILL 硬化节.
umask 077
BUS="${AGENT_MAIL_DIR:-$HOME/.agents/mail}"
REG="$BUS/registry.md"

usage() {
  cat <<'EOF'
agentbus — agent-mail inter-orchestrator mailbox  (root: $AGENT_MAIL_DIR, default ~/.agents/mail)
  agentbus register <agent-id> <workdir> <focus...>  add to roster + create mailbox
  agentbus check <agent-id>                          list pending (inbox, oldest first)
  agentbus send <from> <to> <slug> [subject...]      deliver a letter to recipient inbox (atomic;
                                                       body optional via stdin, empty if a tty)
  agentbus archive <agent-id> <id>                   move a handled letter to archive (gzip'd)
  agentbus prune <agent-id> [days]                   delete archive letters older than N days (default 60)
  agentbus roster                                    print roster
EOF
}

# Letter BODY size thresholds (bytes) — see `send`. BODY_CAP is a hard refusal with no override:
# a payload that size belongs in a file (absolute path + one-line summary in the letter), not in
# the mailbox. BODY_SOFT only warns on stderr (delivery proceeds): the owner wants letters lean —
# every byte of a letter is read by the recipient's context, so brevity is a token budget, not style.
BODY_CAP=8192
BODY_SOFT=2048

# Archive retention (days; owner-set policy: 60). Every `archive` opportunistically prunes the same
# seat's expired letters — no daemon/cron needed; `prune` runs the sweep explicitly. The env var
# overrides the default; an explicit `prune <id> <days>` argument overrides both.
RETENTION_DAYS="${AGENT_MAIL_RETENTION_DAYS:-60}"

prune_archive() { # $1 agent-id  $2 days -> prints deleted count; missing archive counts as 0
  arc="$BUS/$1/archive"
  [ -d "$arc" ] || { echo 0; return 0; }
  # -mtime +N = strictly older than N days; both plain .md (pre-gzip history) and .md.gz age out.
  find "$arc" -maxdepth 1 -type f \( -name '*.md' -o -name '*.md.gz' \) \
    -mtime +"$2" -print -delete | wc -l | tr -d ' '
}

ensure_reg() {
  mkdir -p "$BUS"
  [ -f "$REG" ] || printf '# agent-mail 名册（registry）\n\n| agent-id | 工作目录 | 职责（一句话） |\n|---|---|---|\n' > "$REG"
}

cmd="${1:-}"; shift || true
case "$cmd" in
  register)
    id="${1:?agent-id}"; dir="${2:?workdir}"; shift 2; focus="$*"
    ensure_reg
    mkdir -p "$BUS/$id/inbox" "$BUS/$id/archive" "$BUS/$id/tmp"
    if ! grep -q "| \`$id\` |" "$REG" 2>/dev/null; then
      # insert AFTER the last table row (not file end — a trailing footer note would break the table)
      row="$(printf '| `%s` | `%s` | %s |' "$id" "$dir" "$focus")"
      awk -v row="$row" '{ lines[NR]=$0; if ($0 ~ /^\|/) last=NR }
        END { for(i=1;i<=NR;i++){ print lines[i]; if(i==last) print row } }' "$REG" > "$REG.tmp" && mv "$REG.tmp" "$REG"
      echo "registered $id -> $dir  (mailbox: $BUS/$id)"
    else
      echo "$id already in roster (edit $REG to change)"
    fi
    ;;
  check)
    id="${1:?agent-id}"; ib="$BUS/$id/inbox"
    [ -d "$ib" ] || { echo "no such agent: $id (register first)"; exit 1; }
    # tmp/ (in-flight `send` writes) is a SIBLING of inbox/, never inside it — this glob
    # structurally never sees a half-delivered letter, no special-casing needed.
    n=0
    for f in $(ls "$ib"/*.md 2>/dev/null | sort); do   # id 前缀含时间戳 → 文件名序 = 最旧优先
      n=$((n+1))
      subj="$(grep -m1 '^subject:' "$f" | sed 's/^subject:[[:space:]]*//')"
      frm="$(grep -m1 '^from:' "$f" | sed 's/^from:[[:space:]]*//')"
      printf '  from=%-12s %s  (%s)\n' "$frm" "$subj" "$(basename "$f")"
    done
    [ "$n" -eq 0 ] && echo "  (inbox empty)" || echo "$n pending in $id inbox — oldest first, handle ALL (先到的信不许被遮蔽)"
    ;;
  send)
    from="${1:?from}"; to="${2:?to}"; slug="${3:?slug}"; shift 3; subject="${*:-<subject>}"
    base="$BUS/$to"; ib="$base/inbox"; tmpd="$base/tmp"
    [ -d "$ib" ] || { mkdir -p "$ib" "$base/archive"; echo "note: $to not registered — mailbox created anyway (mail must not bounce); consider: agentbus register $to <workdir> <focus>"; }
    mkdir -p "$tmpd"
    id="$(date +%Y%m%d-%H%M)-$from-$slug"; dest="$ib/$id.md"
    [ -e "$dest" ] && { echo "exists: $dest"; exit 1; }
    # Body is read from stdin when it's not a tty (piped/redirected — the normal shape for an
    # agent/CI caller, incl. this test suite); a real interactive tty is left alone (empty body)
    # so a human at a shell prompt never blocks waiting on Ctrl-D. Read BEFORE touching the
    # filesystem so an oversized letter never creates a tmp file at all.
    body=""
    if [ ! -t 0 ]; then body="$(cat)"; fi
    bodylen=$(printf '%s' "$body" | wc -c | tr -d ' ')
    if [ "$bodylen" -gt "$BODY_CAP" ]; then
      echo "refused: body is $bodylen bytes, cap is $BODY_CAP (pointer-not-payload: write the payload to a file, put its absolute path + a one-line summary + the finding it supports in the letter instead — no override)" >&2
      exit 2
    fi
    if [ "$bodylen" -gt "$BODY_SOFT" ]; then
      echo "warning: letter is $bodylen bytes; aim for <2KB — conclusion first, only the action you need from the recipient, evidence as file paths/URLs not inline content" >&2
    fi
    # Maildir-style atomic delivery: compose fully in tmp/, then a same-fs rename into inbox/.
    # There is no window where inbox/ can contain a half-written letter.
    tmpf="$tmpd/$id.md"
    cat > "$tmpf" <<EOF
---
id: $id
from: $from
to: $to
thread: $slug
re:
subject: $subject
priority: normal
---

EOF
    [ -n "$body" ] && printf '%s\n' "$body" >> "$tmpf"
    mv "$tmpf" "$dest"
    echo "delivered $dest"
    ;;
  archive)
    id="${1:?agent-id}"; mid="${2:?letter-id}"
    src="$BUS/$id/inbox/$mid.md"; [ -e "$src" ] || src="$BUS/$id/inbox/$mid"
    [ -e "$src" ] || { echo "not found in $id inbox: $mid"; exit 1; }
    mkdir -p "$BUS/$id/archive"
    dst="$BUS/$id/archive/$(basename "$src")"
    mv "$src" "$dst"
    # gzip on archive (2026-07-10): a wide `grep -r` over the bus was pulling whole historical
    # letter BODIES into context — a 979KB SQL letter got fully re-ingested this way by a routine
    # sweep. Compressed, the id/filename stays visible via `ls`/`zgrep -l`; content only surfaces
    # on an explicit `zcat`/`zgrep`, so a blind grep can no longer inhale megabytes of old mail.
    gzip -9 -f "$dst"
    echo "archived $(basename "$dst").gz"
    # Opportunistic retention sweep: archiving is the natural moment the archive grows, so prune
    # this seat's expired letters here (silent; a prune failure must never fail the archive).
    prune_archive "$id" "$RETENTION_DAYS" >/dev/null 2>&1 || true
    ;;
  prune)
    id="${1:?agent-id}"; days="${2:-$RETENTION_DAYS}"
    case "$days" in ''|*[!0-9]*) echo "invalid days: $days (positive integer required)" >&2; exit 1;; esac
    n="$(prune_archive "$id" "$days")"
    echo "pruned $n letter(s) older than $days days from $id archive"
    ;;
  roster)
    [ -f "$REG" ] && cat "$REG" || echo "(no registry yet — agentbus register <agent-id> <workdir> <focus>)"
    ;;
  *) usage; [ -z "$cmd" ] || exit 1;;
esac
